# Copie para infrastructure/.env.prod e preencha com valores reais.
# NUNCA commitar o arquivo .env.prod.

# ─── Domínio & URLs ──────────────────────────────────────────────────────────
# Usado pelo NGINX, CORS do backend e bundle do frontend.
APP_DOMAIN=crm.exemplo.com.br
APP_URL=https://crm.exemplo.com.br
FRONTEND_URL=https://crm.exemplo.com.br
NEXT_PUBLIC_API_URL=https://crm.exemplo.com.br/api

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=__GERAR_SENHA_FORTE__
POSTGRES_DB=crm_prod
DATABASE_SCHEMA=crm

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere as chaves antes do primeiro deploy (ver DEPLOY.md):
#   openssl genrsa -out infrastructure/keys/jwt_private.key 2048
#   openssl rsa -in infrastructure/keys/jwt_private.key -pubout -out infrastructure/keys/jwt_public.key
JWT_KEYS_HOST_PATH=./keys
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Rate limit (throttler do NestJS) ────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Integrações externas (deixe vazio se não usar) ─────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@exemplo.com.br
SENDGRID_FROM_NAME=Quality SMI

LOG_LEVEL=info
