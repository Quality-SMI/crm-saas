# URL da API. Deixe vazio para usar /api (relativo) — recomendado.
# Em produção, NGINX faz proxy /api → backend.
# Em dev, next.config.ts faz rewrite /api → http://localhost:3000 (override via NEXT_DEV_API_PROXY).
# NEXT_PUBLIC_API_URL=

# Apenas dev — alvo do rewrite de /api/*
# NEXT_DEV_API_PROXY=http://localhost:3000
