# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://crm:crm_dev_pass@localhost:5432/crm_db
DATABASE_SCHEMA=crm

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256 — gere com: openssl genrsa -out private.key 2048 && openssl rsa -in private.key -pubout -out public.key)
JWT_PRIVATE_KEY_PATH=./keys/private.key
JWT_PUBLIC_KEY_PATH=./keys/public.key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OpenAI (para IA features — opcional no dev)
OPENAI_API_KEY=

# SendGrid (para emails — opcional no dev)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@qualitysmi.com.br
SENDGRID_FROM_NAME=Quality SMI

# Logs
LOG_LEVEL=debug
